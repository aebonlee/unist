# Supabase (VITE_ 접두사 — 클라이언트 import.meta.env 로 접근)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site URL (배포 도메인)
VITE_SITE_URL=https://unist.dreamitbiz.com

# 참고: Google / Kakao 로그인은 Supabase 대시보드 > Authentication > Providers 에서
#       Client ID / Secret 을 설정합니다. (코드 측 배선은 src/utils/auth.ts 에 완료)
